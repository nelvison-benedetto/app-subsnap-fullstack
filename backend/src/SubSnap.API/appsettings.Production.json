//appsettings.Production.json
{
  "ConnectionStrings": {
    "sqlConnection": "Host=PLACEHOLDER_DB_HOST;Port=5432;Database=PLACEHOLDER_DB_NAME;Username=PLACEHOLDER_DB_USER;Password=PLACEHOLDER_DB_PASSWORD"
  },
  "JwtSettings": {
    "Issuer": "BusinessDev",
    "Audience": "PLACEHOLDER_HTTPS_FRONTEND_URL",
    "SecretKey": "PLACEHOLDER_JWT_SECRET_KEY" //sul tuo pc windows su powershell crei una chiave complessa con  [Convert]::ToBase64String((New-Object Byte[] 64 | %{Get-Random -Maximum 256})) > su Coolify nel backend setti la env var JwtSettings__SecretKey=thiskeyappenagenerata. poi ovviamente la env var override questo placehoder here.
  }
}
//su coolify (production) setta auto ASPNETCORE_ENVIRONMENT=Production (coolify lo fa sempre auto)
/*e su Coolify(installato dentro server Hetzner), crei variabili d'ambiente:
ConnectionStrings__sqlConnection -> sostituisce auto ->	PLACEHOLDER_DB_HOST...
JwtSettings__Audience -> sostituisce auto	-> PLACEHOLDER_FRONTEND_URL
JwtSettings__SecretKey	-> sostituisce auto ->  PLACEHOLDER_JWT_SECRET
*/
